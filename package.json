{
  "name": "terminal-dashboard",
  "version": "0.1.0",
  "author": "Tung Tran <tranthaitung.inbox@gmail.com>",
  "description": "Multi-panel terminal dashboard",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-rebuild -f -w node-pty",
    "package": "electron-vite build && electron-builder --mac"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "com.tungtran.terminal-dashboard",
    "productName": "Terminal Dashboard",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "icon": "build/icons/icon.icns"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": []
  }
}
